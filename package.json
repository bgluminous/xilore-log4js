{
  "name": "xilore-log4js",
  "version": "1.0.1",
  "description": "轻量级 TypeScript/Node 日志库，控制台/文件/上传三种输出，支持 JSON/YAML 配置",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Luminous",
  "repository": {
    "type": "git",
    "url": "https://github.com/bgluminous/xilore-log4js.git"
  },
  "keywords": [
    "log",
    "logger",
    "xilore",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "demo": "npm run build && node demo.mjs",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build",
    "publish:dry": "npm publish --access public --dry-run",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "js-yaml": "^4.1.0"
  },
  "dependencies": {
    "source-map-support": "^0.5.21"
  }
}